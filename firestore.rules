rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net: Default Deny All
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE GLOBAL HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- USER PROFILE VALIDATION ---
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'fullName']) &&
             data.email is string && data.email.size() <= 128 &&
             data.fullName is string && data.fullName.size() <= 128;
    }

    // --- CHAT SESSION VALIDATION ---
    function isValidChat(data) {
      return data.keys().hasAll(['id', 'userEmail', 'title', 'createdAt', 'updatedAt', 'mode']) &&
             data.id is string && data.id.size() <= 128 &&
             data.userEmail is string && data.userEmail.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.mode is string && (
               data.mode == 'general' || 
               data.mode == 'research' || 
               data.mode == 'study' || 
               data.mode == 'factcheck' || 
               data.mode == 'writing' || 
               data.mode == 'quiz'
             );
    }

    // --- MESSAGE VALIDATION ---
    function isValidMessage(data) {
      return data.keys().hasAll(['id', 'role', 'content', 'timestamp']) &&
             data.id is string && data.id.size() <= 128 &&
             data.role is string && (data.role == 'user' || data.role == 'assistant') &&
             data.content is string && data.content.size() <= 1048576 &&
             data.timestamp is string && data.timestamp.size() <= 128;
    }

    // --- COLLECTION RULES ---

    // Users Collection
    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasAny(['fullName', 'avatarUrl', 'preferences', 'gamification', 'updatedAt'])
      );
      allow delete: if false; // User accounts cannot be deleted directly from client SDK
    }

    // Connection Test Collection
    match /connection_test/{documentId} {
      allow read, write: if true;
    }

    // Waitlist Collection
    match /waitlist/{emailOrUid} {
      allow get: if isSignedIn() && (
        request.auth.uid == emailOrUid ||
        (request.auth.token != null && request.auth.token.email == emailOrUid) ||
        (request.auth.token != null && request.auth.token.email.matches('(?i)^' + emailOrUid + '$')) ||
        (resource != null && (
          resource.data.uid == request.auth.uid || 
          resource.data.userId == request.auth.uid ||
          (request.auth.token != null && resource.data.email == request.auth.token.email) ||
          (request.auth.token != null && resource.data.email.matches('(?i)^' + request.auth.token.email + '$'))
        ))
      );
      
      allow create: if isSignedIn() && (
        request.auth.uid == emailOrUid ||
        (request.auth.token != null && request.auth.token.email == emailOrUid) ||
        (request.auth.token != null && request.auth.token.email.matches('(?i)^' + emailOrUid + '$'))
      ) &&
      incoming().keys().hasAll(['email', 'timestamp']) &&
      incoming().timestamp is string && incoming().timestamp.size() <= 128 &&
      (incoming().uid == request.auth.uid || incoming().userId == request.auth.uid);

      allow delete: if isSignedIn() && (
        request.auth.uid == emailOrUid ||
        (request.auth.token != null && request.auth.token.email == emailOrUid) ||
        (request.auth.token != null && request.auth.token.email.matches('(?i)^' + emailOrUid + '$')) ||
        (resource != null && (
          resource.data.uid == request.auth.uid || 
          resource.data.userId == request.auth.uid ||
          (request.auth.token != null && resource.data.email == request.auth.token.email) ||
          (request.auth.token != null && resource.data.email.matches('(?i)^' + request.auth.token.email + '$'))
        ))
      );
    }

    // Chat Sessions subcollection
    match /users/{userId}/chats/{chatId} {
      allow get: if isOwner(userId) && isValidId(userId) && isValidId(chatId);
      allow list: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidId(chatId) && isValidChat(incoming());
      allow update: if isOwner(userId) && isValidId(userId) && isValidId(chatId) && isValidChat(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasAny(['title', 'updatedAt', 'messages', 'isPinned', 'pinOrder', 'mode', 'selectedEngineId'])
      );
      allow delete: if isOwner(userId) && isValidId(userId) && isValidId(chatId);

      // Nested messages subcollection
      match /messages/{messageId} {
        allow get: if isOwner(userId) && isValidId(userId) && isValidId(chatId) && isValidId(messageId);
        allow list: if isOwner(userId) && isValidId(userId) && isValidId(chatId);
        allow create: if isOwner(userId) && isValidId(userId) && isValidId(chatId) && isValidId(messageId) && isValidMessage(incoming());
        allow update: if isOwner(userId) && isValidId(userId) && isValidId(chatId) && isValidId(messageId) && isValidMessage(incoming());
        allow delete: if isOwner(userId) && isValidId(userId) && isValidId(chatId) && isValidId(messageId);
      }
    }
  }
}
